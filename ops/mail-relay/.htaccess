# Only index.php is reachable. Without this, the server would hand out any file
# dropped beside the script — including a backup like index.php.bak, which most
# editors create on save and which is served as PLAIN TEXT, token and all.
Options -Indexes

# Deny everything, then allow the one file back. This is deliberately written
# WITHOUT a regex lookahead: the obvious `<FilesMatch "^(?!index\.php$).*$">`
# silently matches nothing under LiteSpeed (which runs this host), so the folder
# reads as protected while serving every file in it. Verified against the live
# server — the lookahead version returned 200 for vfw-relay/index.php.bak.
<Files "*">
    Require all denied
</Files>

<Files "index.php">
    Require all granted
</Files>
