# VFW backend — STAGING environment template.
#
# Staging is a real, remote deployment (its own Railway project), NOT localhost.
# Two rules follow from that:
#   1. Every secret below is DISTINCT from production. Sharing prod's JWT_SECRET,
#      CONFIG_ENC_KEY, mail or R2 credentials with staging means a staging
#      compromise is a production compromise.
#   2. Because the DB is not localhost, the seed's published default password is
#      refused — you MUST set SEED_PASSWORD to seed demo users.
#
# On Railway these are service variables, not a committed file. This template is
# the checklist; the canonical per-variable reference (prod + staging side by
# side) is docs/railway-variables.md, and the bring-up is docs/runbook-staging.md.
# Fill real secrets from the password manager, never commit them.

# Injected by the staging Postgres plugin — reference it, don't hardcode:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=""

# A real deployment: keep the session cookie Secure.
NODE_ENV="production"

# DISTINCT from production. Generate a fresh one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# DISTINCT from production. Same generator as JWT_SECRET. Encrypts stored in-app
# secrets; rotating it makes existing stored secrets unreadable.
CONFIG_ENC_KEY=""

# The staging frontend origin (exact, no trailing slash). Fallback only under the
# single-origin proxy, but keep it correct for this tier.
CORS_ORIGIN="https://<staging-frontend>.up.railway.app"

# Where emailed links point on staging.
APP_URL="https://<staging-frontend>.up.railway.app"

# A NUMBER. Measure it on staging with GET /api/health/ip through the real front
# door once the proxy chain is wired — do not copy prod's value blindly.
TRUST_PROXY_HOPS="1"

# Required to seed a non-localhost DB. A shared demo password is fine on staging
# (it exists to click through the app); keep it out of git regardless.
SEED_PASSWORD=""

# Louder logs are fine on staging.
LOG_LEVEL="debug"

# --- Optional on staging --------------------------------------------------
# Use a SEPARATE Sentry project so staging noise never pages prod's on-call.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0"

# Mail: send from a NON-production mailbox if you wire it at all. Host/port/from
# are not secret; username/password/from-address are.
MAIL_HOST=""
MAIL_PORT=465
MAIL_ENCRYPTION="ssl"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_FROM_ADDRESS=""
MAIL_FROM_NAME="VFW Console (staging)"

# Document storage: a SEPARATE staging bucket + keys scoped to it. Never the prod
# bucket. Identifiers aren't secret; the keys are.
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Do NOT set DEV_ECHO_LINKS here — it is dev-only and ignored when
# NODE_ENV=production anyway.
