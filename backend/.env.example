# Local dev points at docker-compose. Port 5434 (not the default 5432) because
# other stacks on this machine already hold 5432/5433.
# On Railway, the Postgres plugin injects DATABASE_URL for you — do not set it there.
DATABASE_URL="postgresql://vfw:vfw@localhost:5434/vfw?schema=public"

# Sign the session JWT. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev-only-change-me"

# Where the SPA is served from. Must be an exact origin for cookies to work.
CORS_ORIGIN="http://localhost:5173"

# Set to "production" on Railway. This makes the session cookie Secure.
# (It is SameSite=Lax, not None — the frontend proxies /api, so the cookie is
# first-party. See architecture.md §5.)
NODE_ENV="development"

# 3000 is taken by another local stack on this machine.
PORT=3001

# --- Proxy / rate limiting -------------------------------------------------
# How many proxies sit between the caller and this app. The rate limiter keys on
# the client IP, and Express finds it by counting this many hops in from the
# RIGHT of X-Forwarded-For. Get it wrong in either direction and the limiter
# breaks:
#   too low  -> everyone shares the proxy's IP, so all users share one bucket
#               and real people start getting 429s;
#   too high -> the app believes a caller-supplied X-Forwarded-For value, and an
#               attacker just rotates it to get an unlimited number of buckets.
# 0 = no proxy (correct for local dev; req.ip is the socket address).
# On Railway, deploy, call GET /api/health/ip through the real front door, and
# set this to whatever makes `ip` come back as your own address.
TRUST_PROXY_HOPS=0

# --- Observability ---------------------------------------------------------
# Error tracking. Unset = Sentry is disabled entirely and the app runs normally.
# Cookies, request bodies and auth headers are stripped before anything is sent.
SENTRY_DSN=""

# Fraction of requests traced for performance (0 = off). Errors are always sent.
SENTRY_TRACES_SAMPLE_RATE="0"

# pino level: trace|debug|info|warn|error. Defaults to debug locally, info in
# production. Request logs never contain the session cookie, a password or a JWT.
LOG_LEVEL="debug"

# --- Email (SMTP: welcome/OTP, password reset, invitations) -----------------
# One SMTP transport (cPanel, Google Workspace, SES-SMTP, …) drives every
# message, all poured through one global template (see src/common/email.ts).
# Without these, signup and /api/auth/forgot-password return 503 rather than
# silently logging codes — a fallback that looks like it works while quietly
# locking real users out.
MAIL_HOST="mail.example.com"
MAIL_PORT=465                       # 465 = implicit TLS (ssl); 587 = STARTTLS (tls)
MAIL_USERNAME="no-reply@example.com"
MAIL_PASSWORD=""
MAIL_ENCRYPTION="ssl"               # ssl | tls | none
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="VFW Console"        # also the brand name shown in every email

# Optional email theming.
MAIL_BRAND_COLOUR="#0C7A4D"         # accent used for the header and buttons
MAIL_SUPPORT_ADDRESS=""             # shown in the footer; defaults to MAIL_FROM_ADDRESS

# Where the SPA lives, so an emailed link points somewhere real.
APP_URL="http://localhost:5173"

# DEV ONLY, and ignored outright when NODE_ENV=production: when no MAIL_* is set,
# return the OTP / reset token in the API response instead of emailing it, so the
# signup and reset flows can be exercised without a mail account. Never in prod.
DEV_ECHO_LINKS="true"

# --- Document storage (Cloudflare R2 / S3-compatible) -----------------------
# Submission documents (signed contract, PO, receipt) live in object storage,
# never on the app disk — a disk fallback would survive until the first redeploy
# ate a contract. Without these, upload/download return 503; nothing is stored.
# The file goes straight from the browser to R2 with a presigned PUT and comes
# back with a presigned GET; the bytes never pass through this API.
#
# Provide EITHER R2_ENDPOINT or R2_ACCOUNT_ID (the endpoint is derived from the
# account id if only the id is given).
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
