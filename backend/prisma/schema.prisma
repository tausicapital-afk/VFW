// VFW Console — domain schema.
//
// Money is NUMERIC(14,2) everywhere and surfaces as Prisma Decimal. No float
// ever touches a price, a tax amount or a commission.
//
// Records in this system are financial evidence: submissions are never deleted,
// only moved through their status lifecycle, and every transition appends to
// AuditEntry.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// People & access
// ---------------------------------------------------------------------------

enum Role {
  SALES
  INTERN
  ACCT
  MGR
  ADMIN
}

// Signup is invitation-only and still requires an admin to approve the account,
// so a user exists in PENDING before they can authenticate.
enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  DISABLED
}

model User {
  id            String     @id @default(cuid())
  employeeId    String?    @unique
  name          String
  email         String     @unique
  phone         String?
  passwordHash  String
  role          Role
  department    String?
  status        UserStatus @default(PENDING)
  // Operational-only accounts (demo / test logins) that must keep working but
  // stay off the admin Users tab. Hidden is orthogonal to status: a hidden user
  // is still ACTIVE and authenticates normally — it is only filtered out of the
  // admin people listings, never out of auth.
  hidden        Boolean    @default(false)
  // Soft delete. Distinct from `hidden`, which keeps a working account off the
  // listings: a deleted account is gone as far as the app is concerned — it is
  // filtered from every admin listing AND refused at login and by the guard.
  // The row survives only so the audit trail it is named in stays readable.
  // Note this does not free the email: the unique constraint still holds it.
  deletedAt     DateTime?
  // Bumped to invalidate every session this user currently holds. The session
  // JWT carries the value it was minted with; the guard refuses a token whose
  // value has fallen behind. A password reset bumps it, so a stolen session
  // dies with the password that leaked it.
  tokenVersion  Int        @default(0)
  commissionPct Decimal    @default(0) @db.Decimal(5, 2)
  target        Decimal    @default(0) @db.Decimal(14, 2)
  colour        String     @default("#0E0E11")
  // Presence: when this user's last socket disconnected. Powers "last seen".
  lastSeenAt    DateTime?
  // When this user most recently authenticated. Null = has never logged in.
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  submissions       Submission[]     @relation("SubmissionRep")
  approvals         Submission[]     @relation("SubmissionApprover")
  contactsCreated   Contact[]
  paymentsRecorded  Payment[]
  documentsUploaded Document[]
  comments          InternalComment[]
  feedbackRecorded  DesignerFeedback[]
  auditEntries      AuditEntry[]
  invitationsIssued Invitation[]     @relation("InvitationIssuer")
  passwordResets    PasswordReset[]
  emailOtps         EmailOtp[]

  conversationsCreated Conversation[]            @relation("ConvCreator")
  participations       ConversationParticipant[]
  messagesSent         Message[]                 @relation("MsgSender")

  activityLogs         ActivityLog[]
  sessions             UserSession[]

  @@index([role, status])
}

model Invitation {
  id         String    @id @default(cuid())
  code       String    @unique
  role       Role
  department String?
  email      String?
  expiresAt  DateTime
  usedAt     DateTime?
  usedById   String?
  revokedAt  DateTime?
  // Soft delete, and not the same thing as `revokedAt`: revoking is a decision
  // about the invitation that admins are meant to keep seeing afterwards,
  // deleting is a decision about the list. Both stop the code being redeemed —
  // a "deleted" invitation that still let someone sign up would be a trap.
  // The row survives for the audit entries that name it.
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  createdById String
  createdBy   User   @relation("InvitationIssuer", fields: [createdById], references: [id])

  @@index([code])
}

// Brute-force lockout, keyed by the email that was tried rather than by user —
// a failed login against an address that does not exist must not reveal that.
model LoginAttempt {
  email     String    @id
  count     Int       @default(0)
  lockUntil DateTime?
  updatedAt DateTime  @updatedAt
}

model PasswordReset {
  token     String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// One-time 6-digit codes emailed for a specific purpose. Today that is SIGNUP —
// a freshly created account is PENDING and cannot log in until the code sent to
// its inbox is entered, which proves the email is real and reachable. The code
// is stored only as an argon2 hash, exactly like a password: a leaked row must
// not hand someone a working code.
enum OtpPurpose {
  SIGNUP
}

model EmailOtp {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  // Wrong guesses against this code. Enough of them and the code is burned, so a
  // six-digit space cannot be walked by brute force.
  attempts   Int        @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
}

// ---------------------------------------------------------------------------
// Catalog — admin-editable reference data, seeded from the sales decks
// ---------------------------------------------------------------------------

enum Currency {
  USD
  CAD
  GBP
  EUR
  JPY
}

model TaxProfile {
  code  String  @id
  label String
  rate  Decimal @db.Decimal(6, 3)
  gst   Decimal @default(0) @db.Decimal(6, 3)
  pst   Decimal @default(0) @db.Decimal(6, 3)
  hst   Decimal @default(0) @db.Decimal(6, 3)
  note  String?

  cities      City[]
  packages    Package[]
  submissions Submission[]
}

model City {
  id       String   @id
  name     String
  country  String
  currency Currency

  taxCode String
  tax     TaxProfile @relation(fields: [taxCode], references: [code])

  events      Event[]
  prices      PackagePrice[]
  submissions Submission[]
}

model Event {
  id     String   @id
  brand  String
  name   String
  season String
  venue  String?
  start  DateTime @db.Date
  end    DateTime @db.Date

  cityId String
  city   City   @relation(fields: [cityId], references: [id])

  submissions Submission[]

  @@index([brand])
}

model GlAccount {
  code String @id
  name String

  packages    Package[]
  addons      Addon[]
  submissions Submission[]
}

model Package {
  id    String  @id
  brand String
  name  String
  looks Int
  blurb String?
  // Sponsored packages are billed at a nominal fee; listValue records the
  // revenue that was forgone so reporting can show it.
  listValue Decimal? @db.Decimal(14, 2)
  // Some packages are capped per event (VKFW VIP: only 2 exist).
  cap       Int?

  taxCode String
  tax     TaxProfile @relation(fields: [taxCode], references: [code])
  glCode  String
  gl      GlAccount  @relation(fields: [glCode], references: [code])

  prices      PackagePrice[]
  submissions Submission[]

  @@index([brand])
}

// A package has a different price and currency in every city it is sold in,
// so price cannot live on Package itself.
model PackagePrice {
  id        String   @id @default(cuid())
  packageId String
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  currency  Currency
  price     Decimal  @db.Decimal(14, 2)

  @@unique([packageId, cityId])
}

model Addon {
  id       String   @id
  brand    String
  name     String
  price    Decimal  @db.Decimal(14, 2)
  currency Currency
  note     String?
  // Which brands may buy this add-on.
  forBrands String[]

  glCode String
  gl     GlAccount @relation(fields: [glCode], references: [code])

  lines SubmissionAddon[]

  @@index([brand])
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

model Contact {
  id       String  @id @default(cuid())
  brand    String
  designer String
  company  String?
  email    String?
  phone    String?
  country  String?
  type     String  @default("Designer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  submissions Submission[]
  feedback    DesignerFeedback[]

  // One contact per brand name — the mockup auto-creates a contact the first
  // time a sale is submitted for a brand it has not seen.
  @@unique([brand])
  @@index([designer])
}

// ---------------------------------------------------------------------------
// Submissions — the core record
// ---------------------------------------------------------------------------

enum SubmissionStatus {
  DRAFT
  PENDING
  RETURNED
  APPROVED
  REJECTED
  EXPORTED
}

enum PayStatus {
  UNPAID
  PARTIAL
  PAID
}

enum DiscountType {
  PCT
  AMT
}

model Submission {
  id     String           @id @default(cuid())
  ref    String           @unique
  status SubmissionStatus @default(DRAFT)

  repId String
  rep   User   @relation("SubmissionRep", fields: [repId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  cityId  String
  city    City   @relation(fields: [cityId], references: [id])

  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  showDate DateTime? @db.Date
  notes    String?

  // --- Money. All of it is computed server-side by PricingService; the client
  // --- sends inputs (package, addons, discount) and never sends a total.
  currency     Currency
  packagePrice Decimal      @db.Decimal(14, 2)
  addonTotal   Decimal      @default(0) @db.Decimal(14, 2)
  subtotal     Decimal      @db.Decimal(14, 2)
  discountType DiscountType @default(PCT)
  discountValue Decimal     @default(0) @db.Decimal(14, 2)
  discountAmount Decimal    @default(0) @db.Decimal(14, 2)
  taxable      Decimal      @db.Decimal(14, 2)
  taxRate      Decimal      @db.Decimal(6, 3)
  taxAmount    Decimal      @db.Decimal(14, 2)
  total        Decimal      @db.Decimal(14, 2)
  deposit      Decimal      @default(0) @db.Decimal(14, 2)
  paidAmount   Decimal      @default(0) @db.Decimal(14, 2)
  balance      Decimal      @db.Decimal(14, 2)
  payStatus    PayStatus    @default(UNPAID)

  // Commission is struck on net revenue (taxable), never on tax.
  commissionPct    Decimal @default(0) @db.Decimal(5, 2)
  commissionAmount Decimal @default(0) @db.Decimal(14, 2)

  paymentMethod String?
  paymentTerms  String?

  taxCode String
  tax     TaxProfile @relation(fields: [taxCode], references: [code])

  // Accounting classification, set at approval time.
  glCode     String?
  gl         GlAccount? @relation(fields: [glCode], references: [code])
  costCentre String?
  department String?

  submittedAt DateTime?
  approvedAt  DateTime?
  approvedById String?
  approvedBy   User?     @relation("SubmissionApprover", fields: [approvedById], references: [id])
  rejectedAt  DateTime?
  rejectReason String?
  returnNote  String?
  exportedAt  DateTime?
  qbDocNumber String?
  invoiceNo   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addons   SubmissionAddon[]
  payments Payment[]
  documents Document[]
  comments InternalComment[]
  audit    AuditEntry[]

  @@index([status])
  @@index([repId, status])
  @@index([eventId])
}

// Add-on price is copied onto the line at submission time. If Accounting
// later changes the catalog price, historical submissions must not move.
model SubmissionAddon {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  addonId      String
  addon        Addon      @relation(fields: [addonId], references: [id])
  qty          Int        @default(1)
  unitPrice    Decimal    @db.Decimal(14, 2)
  currency     Currency
  amount       Decimal    @db.Decimal(14, 2)

  @@unique([submissionId, addonId])
}

model Payment {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  amount       Decimal    @db.Decimal(14, 2)
  currency     Currency
  method       String
  reference    String?
  createdAt    DateTime   @default(now())

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  @@index([submissionId])
}

model Document {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  type         String
  filename     String
  // Object-storage key (R2/S3). The file itself never lives on the app disk.
  storageKey   String
  contentType  String?
  size         Int?
  uploadedAt   DateTime   @default(now())

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@index([submissionId])
}

// Confidential: visible to ACCT/MGR/ADMIN only. Never shown to the rep and
// explicitly excluded from the leaderboard score.
model InternalComment {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  department   String
  body         String
  createdAt    DateTime   @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([submissionId])
}

model DesignerFeedback {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  rating    Int
  body      String?
  createdAt DateTime @default(now())

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  @@index([contactId])
}

// Append-only. Nothing in this table is ever updated or deleted — the UI
// advertises that guarantee and Accounting relies on it.
model AuditEntry {
  id           String     @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  action       String
  detail       String?
  // Before/after payloads for money-affecting changes.
  payload      Json?
  createdAt    DateTime   @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([submissionId, createdAt])
  @@index([createdAt])
}

// Single-row table (id is pinned to 1).
model Settings {
  id                  Int     @id @default(1)
  company             String  @default("VFW Management Inc.")
  fiscalYear          Int     @default(2026)
  invoicePrefix       String  @default("VFW-")
  nextInvoiceSeq      Int     @default(2041)
  // Allocated the same way as nextInvoiceSeq — by incrementing this row inside
  // the creating transaction, which takes a row lock. Counting submissions
  // instead would hand the same ref to two concurrent creates.
  nextSubmissionSeq   Int     @default(1001)
  // Discounts above this percentage need explicit accounting sign-off.
  discountApprovalPct Decimal @default(15) @db.Decimal(5, 2)
  qbRealmId           String?
  // FX rates to CAD, the reporting currency. Held here so Accounting can
  // update them without a deploy.
  fxRates             Json    @default("{\"CAD\":1,\"USD\":1.37,\"GBP\":1.74,\"EUR\":1.49,\"JPY\":0.0092}")
  scoreWeights        Json    @default("{\"revenue\":30,\"approved\":20,\"collection\":30,\"retention\":20}")
  updatedAt           DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// System configuration — the operational credentials (SMTP, object storage)
// that used to live only in .env / Railway variables, moved into the database
// so a non-technical administrator can set them from the console.
//
// One row per setting, keyed by the SAME name as the environment variable it
// shadows (MAIL_HOST, R2_BUCKET, …). Resolution order in ConfigService is
// DB row -> process.env -> built-in default, so an existing env-only deployment
// keeps working untouched and the DB simply overrides it when a value is set.
//
// `encrypted` marks a secret (SMTP password, R2 secret key): its `value` is
// AES-256-GCM ciphertext, never plaintext, and is never returned to the browser.
// See src/config/config.crypto.ts and config.registry.ts.
// ---------------------------------------------------------------------------
model ConfigSetting {
  key         String   @id
  value       String
  encrypted   Boolean  @default(false)
  // Who last changed it. A plain column, not an FK: the audit trail is the
  // system of record for "who changed what", so a relation here is redundant.
  updatedById String?
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Mail accounts — the SMTP mailboxes the app can send from.
//
// The credentials for sending live HERE rather than in ConfigSetting, because
// one key/value row per setting can only ever describe one mailbox: a second
// account has nowhere to go, and switching means retyping four fields and
// losing the old ones. One row per mailbox, exactly one marked `isActive`, and
// switching sender is a single click.
//
// `password` is AES-256-GCM ciphertext (see config.crypto.ts) — never
// plaintext, and never returned to the browser.
//
// The MAIL_* environment variables still work: when this table is EMPTY,
// EmailService falls back to resolving MAIL_HOST/MAIL_USERNAME/… through
// ConfigService, so an env-only deployment keeps sending untouched. The first
// account created takes over.
//
// "Exactly one active" is enforced in MailAccountService.activate() inside a
// transaction, not by a partial unique index: Prisma cannot express
// `UNIQUE (isActive) WHERE isActive` in schema, so an index added by raw SQL
// would read as drift on the next migrate.
// ---------------------------------------------------------------------------
model MailAccount {
  id          String   @id @default(cuid())
  // What an admin calls it in the picker — "VFW (cPanel)", "Tausi (Gmail)".
  label       String
  // smtp | resend. How the message leaves the building.
  //
  // This exists because the host decides what is possible: Railway silently
  // drops every outbound SMTP port (measured — see docs/email-and-otp.md), so on
  // that platform `smtp` can never deliver no matter how correct the mailbox is,
  // while `resend` goes over 443 like any other API call. Keeping both means the
  // cPanel mailbox stays configured and usable the moment the app runs somewhere
  // that permits SMTP.
  provider    String   @default("smtp")
  // SMTP-only. Ignored (and left blank) for HTTP providers.
  host        String   @default("")
  port        Int      @default(465)
  // ssl | tls | none. A string, not an enum: adding a mode should not need a
  // migration, and the value is validated on write.
  encryption  String   @default("ssl")
  // SMTP: the login. HTTP providers: unused.
  username    String   @default("")
  // The one secret, AES-256-GCM ciphertext either way: the SMTP password, or the
  // provider API key. One encrypted column rather than two, because it is the
  // same thing — the credential that proves we may send.
  password    String
  fromAddress String
  // Overrides MAIL_FROM_NAME as the brand shown at the top of every email, so
  // switching account can also switch the brand. Blank = fall back to config.
  fromName    String?
  isActive    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // The same mailbox on the same server twice is always a mistake. Scoped by
  // provider so an SMTP and an HTTP account may share a from-address (they will:
  // the same mailbox, reached two different ways).
  @@unique([provider, host, username, fromAddress])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// Messaging — team chat (DMs + groups). Real-time over WebSockets.
//
// This is NOT financial evidence: messages are deliberately kept out of
// AuditEntry, which is submission-scoped and append-only for accounting. These
// tables are additive and touch nothing in the money loop.
// ---------------------------------------------------------------------------

enum ConversationKind {
  DM
  GROUP
}

model Conversation {
  id    String           @id @default(cuid())
  kind  ConversationKind @default(DM)
  title String? // group only

  // For a DM: the two userIds sorted and joined ("a:b"), so opening the same DM
  // twice reuses the one thread instead of forking a second. Null for groups.
  dmKey String? @unique

  createdById   String
  createdBy     User     @relation("ConvCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  // Group admin (rename / add / remove participants). Always false for a DM.
  isAdmin  Boolean   @default(false)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  // Receipt cursors — the WhatsApp model. Instead of one row per message per
  // recipient, each participant carries the ordinal (Message.seq) of the last
  // message delivered to / read by them. Ticks are computed by comparison.
  lastReadSeq      Int @default(0)
  lastDeliveredSeq Int @default(0)

  mutedUntil DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id String @id @default(cuid())

  // Global monotonic ordinal. cuid is not orderable and createdAt can tie, so
  // seq is the single source of truth for "before / after" and for the cursors.
  seq Int @default(autoincrement())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MsgSender", fields: [senderId], references: [id])

  body      String? // null for a pure-media message
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime? // soft delete → "this message was deleted"

  attachments MessageAttachment[]

  @@index([conversationId, seq])
}

model MessageAttachment {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Object-storage key (R2/S3): messages/<conversationId>/<cuid>-<filename>.
  // The bytes never pass through the API — same presigned model as Document.
  storageKey  String
  filename    String
  contentType String
  size        Int?
  width       Int? // image dimensions, so the UI reserves space without reflow
  height      Int?
}

// ---------------------------------------------------------------------------
// Activity — operational telemetry for the admin-only Logs screen.
//
// This is NOT financial evidence and is deliberately kept out of AuditEntry,
// which is submission-scoped and append-only for accounting. These tables
// record who signed in, what modules they opened, and who messaged whom
// (metadata only — never message text). Additive: they touch nothing in the
// money loop. Nothing writes back over a row; the screen is read-only.
// ---------------------------------------------------------------------------

model ActivityLog {
  id     String @id @default(cuid())
  // Null-able and SetNull on delete: a log line outlives the account it names.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // LOGIN, LOGOUT, CONNECT, DISCONNECT, MODULE_VIEW, MESSAGE_SENT.
  action String
  // Human one-liner for the feed: "Entered Messages", "Messaged Jane Doe".
  detail String?
  // Structured context: { module, conversationId, recipientId, durationSec }.
  // Never message content.
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// One row per online session, opened when a user's first socket connects and
// closed when their last one disconnects. durationSec is filled on close, so a
// still-open session (endedAt null) is someone online right now.
model UserSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?
  ip          String?
  userAgent   String?

  @@index([userId, startedAt])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Health — the record behind the public status page (GET /api/health in a
// browser). One row per component per probe, written by the background prober
// in backend/src/health/.
//
// This exists because uptime cannot be computed from the present tense. A live
// check can only ever say "up right now"; the 90-day bars on the status page
// need a history, and this is it. Nothing reads back over a row — a probe is a
// dated observation, so it is written once and later aged out.
//
// Not financial evidence and deliberately not in AuditEntry, same reasoning as
// ActivityLog above. Rows expire after 90 days (see RETENTION_DAYS), which is
// exactly the window the page draws.
// ---------------------------------------------------------------------------

model HealthProbe {
  id String @id @default(cuid())

  // "api" | "database" | "storage" | "email" — see COMPONENTS in health.service.ts.
  component String
  // OPERATIONAL | DEGRADED | DOWN | UNCONFIGURED.
  //
  // UNCONFIGURED is not an outage: it means the credentials were never set, so
  // there is nothing to be down. Uptime maths excludes those rows entirely
  // rather than counting them against the service.
  status String
  // Round-trip of the probe itself. Null when there was nothing to time.
  latencyMs Int?
  // Why it failed, for an operator reading the table directly. Never rendered
  // on the public page and never returned by the API — a connection error
  // names hosts and ports.
  error     String?
  checkedAt DateTime @default(now())

  // The page's query: one component, last 90 days, bucketed by day.
  @@index([component, checkedAt])
  // Retention sweeps by age across every component.
  @@index([checkedAt])
}
