# Absolute base URL of the deployed VFW API (no trailing slash), e.g.
#   VITE_API_BASE=https://vfw-api.up.railway.app
#
# Vite inlines this at BUILD time, so on Railway it must be set as a service
# variable before the frontend builds. Leave it empty for local dev —
# vite.config.ts proxies /api to http://localhost:3001.
VITE_API_BASE=
